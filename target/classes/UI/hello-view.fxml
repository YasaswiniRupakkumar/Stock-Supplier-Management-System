<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="Controllers.HelloController">
  <top>
    <Label text="John’s Super Market" style="-fx-font-size: 20px; -fx-padding: 10;" />
  </top>

  <center>
    <TabPane fx:id="mainTabPane">
      <Tab text="Low Stock Items" closable="false">
        <VBox spacing="10">
          <padding>
            <Insets top="10" bottom="10" left="10" right="10"/>
          </padding>
          <TableView fx:id="lowStockTable" prefHeight="400">
            <columns>
              <TableColumn fx:id="itemCodeCol" text="Item Code"/>
              <TableColumn fx:id="nameCol" text="Name"/>
              <TableColumn fx:id="brandCol" text="Brand"/>
              <TableColumn fx:id="categoryCol" text="Category"/>
              <TableColumn fx:id="priceCol" text="Price"/>
              <TableColumn fx:id="quantityCol" text="Quantity"/>
              <TableColumn fx:id="thresholdCol" text="Threshold"/>
              <TableColumn fx:id="purchaseDateCol" text="Purchase Date"/>
              <TableColumn fx:id="imageCol" text="Image"/>
            </columns>
          </TableView>
          <Label fx:id="lowStockStatusLabel"/>
        </VBox>
      </Tab>

      <Tab text="Inventory Management" closable="false">
        <AnchorPane fx:id="inventoryPane"/>
      </Tab>

      <Tab text="Dealer Management" closable="false">
        <fx:include source="DealerTab.fxml"/>
      </Tab>
    </TabPane>
  </center>

  <bottom>
    <HBox spacing="10" alignment="CENTER">
      <padding>
        <Insets top="10" bottom="10" left="10" right="10"/>
      </padding>
      <Button text="Save to File" onAction="#onSave"/>
      <Button text="Exit" onAction="#onExit"/>
    </HBox>
  </bottom>
</BorderPane>
