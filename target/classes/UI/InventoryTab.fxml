<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml" fx:controller="Controllers.InventoryController">
    <padding>
        <Insets top="10" bottom="10" right="10" left="10"/>
    </padding>

    <Label text="Inventory Management" style="-fx-font-size: 16px;" />

    <!-- Input Form -->
    <GridPane hgap="10" vgap="10">
        <Label text="Item Code:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="itemCodeField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Name:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="nameField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Brand:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="brandField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Category:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="categoryField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Price:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <TextField fx:id="priceField" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

        <Label text="Quantity:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
        <TextField fx:id="quantityField" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

        <Label text="Low Stock Threshold:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
        <TextField fx:id="lowStockField" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

        <Label text="Supplier ID:" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
        <TextField fx:id="supplierIdField" GridPane.rowIndex="3" GridPane.columnIndex="3"/>

        <Label text="Image Path:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <HBox spacing="5" GridPane.rowIndex="4" GridPane.columnIndex="1" GridPane.columnSpan="3">
            <TextField fx:id="imagePathField" HBox.hgrow="ALWAYS" promptText="Drag &amp; drop image here or browse..."/>
            <Button text="Browse" onAction="#onBrowseImage"/>
        </HBox>
    </GridPane>

    <!-- Table -->
    <TableView fx:id="inventoryTable" prefHeight="300">
        <columns>
            <TableColumn fx:id="itemCodeCol" text="Item Code" prefWidth="100"/>
            <TableColumn fx:id="nameCol" text="Name" prefWidth="120"/>
            <TableColumn fx:id="brandCol" text="Brand" prefWidth="120"/>
            <TableColumn fx:id="categoryCol" text="Category" prefWidth="100"/>
            <TableColumn fx:id="priceCol" text="Price" prefWidth="80"/>
            <TableColumn fx:id="quantityCol" text="Quantity" prefWidth="80"/>
            <TableColumn fx:id="purchaseDateCol" text="Purchase Date" prefWidth="110"/>
            <TableColumn fx:id="imageCol" text="Image" prefWidth="60"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <!-- Buttons -->
    <HBox spacing="10">
        <Button text="Add Item" onAction="#onAddItem"/>
        <Button text="Update Item" onAction="#onUpdateItem"/>
        <Button text="Delete Item" onAction="#onDeleteItem"/>
        <Button text="Refresh" onAction="#onRefresh"/>
    </HBox>

    <!-- Success Message -->
    <Label fx:id="successMessageLabel" style="-fx-text-fill: green; -fx-border-color: green; -fx-padding: 5;" visible="false"/>

    <!-- Totals -->
    <Label fx:id="totalItemCountLabel"/>
    <Label fx:id="totalValueLabel"/>
</VBox>
